{
  "hooks": {
    "UserPromptSubmit": [
      {
        "command": "python3 .claude/skills/self-improve/scripts/activator.py \"$PROMPT\""
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "command": "python3 .claude/skills/self-improve/scripts/error_detector.py \"$EXIT_CODE\" \"$STDOUT\" \"$STDERR\""
      }
    ],
    "Stop": [
      {
        "command": "python3 .claude/skills/self-improve/scripts/session_flush.py"
      }
    ]
  }
}
