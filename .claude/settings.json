{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/activator.py \"$PROMPT\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/handoff_nudge.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/error_detector.py \"$EXIT_CODE\" \"$STDOUT\" \"$STDERR\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/session_flush.py"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/teammate_idle.py"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/task_completed.py"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/task_created.py"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "vault/**/*.md",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/skills/self-improve/scripts/vault_file_changed.py \"$FILE_PATH\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
