# Discord Bot Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=your-bot-token-here

# Your Discord user ID (right-click your username → Copy User ID)
ALLOWED_USER_IDS=your-user-id-here

# Path to the AI Harness project root (where CLAUDE.md lives)
HARNESS_ROOT=$HOME/Desktop/AI-Harness

# Discord channel ID for #agent-stream (subagent activity feed)
# Create a channel, right-click → Copy Channel ID
STREAM_CHANNEL_ID=

# Maximum concurrent Claude processes (default: 5)
MAX_CONCURRENT_PROCESSES=5

# Default timeout for subagent tasks in seconds (default: 300)
SUBAGENT_TIMEOUT=300

# Canvas LMS iCal feed URL (optional — enables assignment reminders)
# Found in Canvas → Calendar → Calendar Feed
CANVAS_ICAL_URL=

# Microsoft (Azure AD app registration — personal account)
# Portal: https://portal.azure.com → App registrations
# Redirect URI: http://localhost:3847/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# LinkedIn — Share on LinkedIn (posting)
# Portal: https://www.linkedin.com/developers
# Redirect URI: http://localhost:3847/callback
# Scopes: w_member_social openid profile
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# LinkedIn — Community Management API (commenting, reactions, reading)
# MUST be a separate LinkedIn app (LinkedIn requires this product to be solo)
# Scopes: w_member_social w_member_social_comments r_member_social openid profile
LINKEDIN_COMMUNITY_CLIENT_ID=
LINKEDIN_COMMUNITY_CLIENT_SECRET=

# Token encryption key (32 bytes = 64 hex chars)
# Generate: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=
