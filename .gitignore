# Public-repo boundary:
# Track source code, tests, and example/template files.
# Ignore local runtime state, secrets, generated artifacts, and personal vault/planning notes.

# Package manager / build outputs
node_modules/
dist/
build/
*.tgz

# Local secrets / env files
.env
.env.local

# Generic logs / OS noise
*.log
*.log.*
.DS_Store

# Repo-local runtime artifacts
.claude/heartbeat-state/
.claude/worktrees/
.tmp/
.bot.pid
harness.db
harness.db-wal
harness.db-shm
*.json.bak

# Pre-edit backups (Claude/Codex sometimes create *.bak.<descriptive-suffix>)
*.bak
*.bak.*

# Vendored dependencies (regenerated locally; too large for git)
vendor/

# Notifications queue (sometimes drained to project root)
pending-notifications.jsonl

# Generated caches
__pycache__/
heartbeat-tasks/.cs2600-cache/
vault/vault-embeddings.json

# Project-local state and private knowledge
vault/.obsidian/
vault/shared/project-knowledge/*.md
!vault/shared/project-knowledge/_example.md
vault/shared/course-notes/
projects/
context-log/

# Heartbeat task local data
heartbeat-tasks/*.state.json
heartbeat-tasks/*.state-files.json
heartbeat-tasks/*.vercel-state.json
heartbeat-tasks/*.json
heartbeat-tasks/pending-notifications.jsonl
bridges/discord/pending-notifications.jsonl
heartbeat-tasks/semantic-dedup-audit.jsonl
heartbeat-tasks/logs/*.log
heartbeat-tasks/projects.json
!heartbeat-tasks/projects.example.json
heartbeat-tasks/course-map.json
!heartbeat-tasks/course-map.example.json

# Vault entries contain personal session data and should not ship in a public repo
vault/LIVE_STATE.md
vault/.error-hashes
vault/*.canvas
vault/*.base
vault/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9].md
vault/learnings/*
!vault/learnings/.gitkeep
vault/shared/*.md
vault/shared/scouted/*
!vault/shared/scouted/.gitkeep
vault/agents/*
!vault/agents/.gitkeep
vault/shared/*digest.md

# Local/private Claude agent definitions
.claude/agents/client-project.md
.claude/agents/mento.md
.claude/agents/lightrag.md
.claude/agents/lattice.md
.claude/agents/*.md
!.claude/agents/.gitkeep

# Skill symlinks into external companion repos (e.g. cptc-toolkit).
# Local convenience for tandem development; the skills themselves
# live in their own repos and shouldn't be re-tracked here.
.claude/skills/cptc-report

# Development planning docs contain personal project references
PLAN.md
PLAN-*.md
CONTEXT.md
vault/daily/

# Discord bridge local runtime state
bridges/discord/.local/
bridges/discord/.tmp/
bridges/discord/__pycache__/
bridges/discord/.env
bridges/discord/.bot.pid
bridges/discord/harness.db
bridges/discord/harness.db-shm
bridges/discord/harness.db-wal
bridges/discord/bot.log
bridges/discord/bot.log.*
bridges/discord/projects.json.bak
.worktrees/
.bg-jobs/

# Control-panel AI autorun kill-switch (transient runtime state)
.autorun-mode
.usage-state.json
.usage-limits.json
